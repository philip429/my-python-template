[project]
name = "{{ project_name | replace('_', '-') }}"
version = "0.1.0"
description = "{{ project_description }}"
readme = "README.md"
requires-python = ">={{ python_version }}"
authors = [{ name = "{{ author_name }}" }]
dependencies = [
    "ipykernel>=6.29",
    "jupyterlab>=4.2",
    "matplotlib>=3.9",
    "numpy>=2.0",
    "pandas>=2.2",
    "pyyaml>=6.0",
    "scikit-learn>=1.5",
    "seaborn>=0.13",
]

[dependency-groups]
dev = [
    "pytest>=8.2",
    "pytest-cov>=5.0",
    "ruff>=0.5",
]

[project.scripts]
{{ project_name | replace('_', '-') }} = "{{ project_name }}.main:main"

[tool.ruff]
extend-include = ["*.ipynb"]
line-length = 88
target-version = "py{{ python_version | replace('.', '') }}"

[tool.ruff.lint]
select = ["B", "E", "F", "I", "UP"]

[tool.ruff.format]
quote-style = "double"
indent-style = "space"

[tool.pytest.ini_options]
addopts = "--cov={{ project_name }} --cov-report=term-missing"
testpaths = ["tests"]

[tool.coverage.run]
source = ["{{ project_name }}"]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"
